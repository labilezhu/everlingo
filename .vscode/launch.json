{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "everlingo",
            "type": "debugpy",
            "request": "launch",
            "module": "everlingo",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "wechat",
            "type": "debugpy",
            "request": "launch",
            "module": "everlingo.test_wechat",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "indexer",
            "type": "debugpy",
            "request": "launch",
            "module": "everlingo",
            "args": ["mem", "indexer", "start"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "justMyCode": true
        },        
        {
            "name": "gateway --channel_wechat",
            "type": "debugpy",
            "request": "launch",
            "module": "everlingo.gateway.gateway",
            "args": ["--channel_wechat"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "justMyCode": false
        },        
        {
            "name": "gateway --channel_web",
            "type": "debugpy",
            "request": "launch",
            "module": "everlingo.gateway.gateway",
            "args": ["--channel_web"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
